# DomFix API Configuration

# ============================================
# GOOGLE DIRECTIONS API KEY
# ============================================
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable: Directions API, Maps SDK for Android, Maps SDK for iOS
# 
# Add your key in: lib/services/route_service.dart (line 19)
# Replace: YOUR_GOOGLE_API_KEY_HERE
# With: Your actual API key
#
# Example:
# static const String _googleApiKey = 'AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXX';
#
# Leave empty to use FREE OSRM routing (no API key required)

GOOGLE_DIRECTIONS_API_KEY=

# ============================================
# NOTES
# ============================================
# - Google Directions: $200 free/month (~40,000 requests)
# - OSRM: 100% FREE, no limits, no key required
# - App uses OSRM as automatic fallback if Google fails

# ============================================
# GROQ AI API KEY
# ============================================
# Get your free key from: https://console.groq.com/keys
# Use this if you don't want to deploy the Firebase Cloud Function
# Provide it via --dart-define=DOMFIX_GROQ_API_KEY=YOUR_KEY
#
# DOMFIX_GROQ_API_KEY=
