# ============================================
# DomFix Backend Configuration
# ============================================

# The port to run the Express server on (default: 3000)
PORT=3000

# ============================================
# GROQ AI CONFIGURATION
# ============================================
# Get your free API key from: https://console.groq.com/keys
# This key stays secure on the server and is used by the AI endpoints.
GROQ_API_KEY=gsk_your_api_key_here

# ============================================
# FIREBASE CREDENTIALS
# ============================================
# For local development, place your Firebase service account key in:
# backend/serviceAccountKey.json
# 
# For production (e.g. Render, Heroku), you can provide the JSON string here:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"domotique-c7923",...}
